+    Carriage returns and newlines that arrive as part of a bracketed paste are
+    treated as secret content and dropped (flattened away) rather than acting as
+    Enter, so long or multi-line keys are captured in full. The returned value
+    is stripped of surrounding whitespace so it lands on a single clean line.
+    """
     value: list[str] = []
+    in_paste = False
     write(prompt)
 
     while True:
@@ -30,8 +50,12 @@ def _collect_masked_input(
