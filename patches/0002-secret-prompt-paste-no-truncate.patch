 _ENTER_CHARS = {"\r", "\n"}
 _EOF_CHARS = {"\x04", "\x1a"}
 
+# Bracketed paste markers (the bytes that follow the leading ESC). When the
+# application enables paste reporting (ESC[?2004h), terminals wrap pasted text
+# in ESC[200~ ... ESC[201~. We use them so a newline *inside* a pasted secret —
+# a key copied with a trailing newline, or one wrapped across several lines —
+# does NOT submit/truncate the value the way a real Enter keypress does. The
+# secret is flattened to a single line instead of being cut off at the first
+# newline (with the remainder leaking to the shell).
+_PASTE_START = "[200~"
+_PASTE_END = "[201~"
+_BRACKETED_PASTE_ON = "\x1b[?2004h"
+_BRACKETED_PASTE_OFF = "\x1b[?2004l"
+
 
