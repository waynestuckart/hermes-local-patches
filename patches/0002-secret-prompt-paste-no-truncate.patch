+    def _poll_read() -> str:
+        # Read one more byte only if it is already waiting, so a bare Escape
+        # keypress (nothing following) does not block.
+        ready, _, _ = select.select([fd], [], [], 0.02)
+        if not ready:
+            return ""
+        return sys.stdin.read(1)
+
+    def read_escape() -> str:
+        # ESC has just been read. Gather the remainder of the sequence: a CSI
+        # (ESC[...final) covers the bracketed-paste markers and arrow keys; an
+        # SS3 (ESC O x) covers some function keys. Anything else is a bare ESC.
+        first = _poll_read()
+        if not first:
+            return ""
+        seq = [first]
+        if first == "[":
+            while True:
+                c = _poll_read()
+                if not c:
+                    break
+                seq.append(c)
+                if "@" <= c <= "~":  # CSI final byte
+                    break
+        elif first == "O":
+            c = _poll_read()
+            if c:
+                seq.append(c)
+        return "".join(seq)
