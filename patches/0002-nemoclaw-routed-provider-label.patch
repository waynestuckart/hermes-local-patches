+def _is_nemoclaw_routed_endpoint(base_url: str) -> bool:
+    """True when ``base_url`` is NVIDIA NemoClaw's in-sandbox inference route.
+
+    NemoClaw (https://github.com/NVIDIA/NemoClaw) runs Hermes inside an
+    OpenShell sandbox and points ``model.base_url`` at
+    ``https://inference.local/v1`` — a host-side router that forwards to the
+    operator-selected provider while keeping real credentials off the sandbox.
+    Hermes sees a generic ``provider: custom`` endpoint; without this check
+    the picker/status surfaces just say "Custom endpoint", which gives no clue
+    that traffic is actually being routed and managed by NemoClaw.
+    """
+    try:
+        return urllib.parse.urlparse(base_url.strip()).hostname == "inference.local"
+    except Exception:
+        return False
+
